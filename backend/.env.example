# ===========================================================
# XLSX-to-BI 环境变量配置
# ===========================================================
# 复制此文件为 .env 并修改配置

# ===========================================================
# Agent 后端选择
# ===========================================================
# local    - 本地 LLM 提示词模式（推荐，需要 DeepSeek API Key）
# shenzhou - 神州问学平台（预留，待对接）
AGENT_BACKEND=local

# ===========================================================
# LLM（API 地址、Key、主/备模型）
# 仅在管理后台「LLM 配置」中维护并启用，不在 .env 中配置
# ===========================================================

# ===========================================================
# 神州问学平台（AGENT_BACKEND=shenzhou 时使用，预留）
# ===========================================================
# SHENZHOU_API_BASE=https://api.shenzhou.com
# SHENZHOU_API_KEY=

# ===========================================================
# Agent 超时与重试配置
# ===========================================================
AGENT_MAX_RETRIES=2
AGENT_DEFAULT_TIMEOUT=60
AGENT_SQL_TIMEOUT=30
AGENT_SHEET_SUMMARY_TIMEOUT=20
AGENT_CHART_TIMEOUT=20
AGENT_REPORT_TIMEOUT=30

# ===========================================================
# 服务配置
# ===========================================================
DATABASE_URL=mysql+aiomysql://root:your-password@127.0.0.1:3306/xlsx_to_bi?charset=utf8mb4
SERVER_PORT=8007
# JWT 密钥：长度必须 >= 32 位，严禁使用默认值；可使用 openssl rand -base64 32 生成
JWT_SECRET_KEY=change-this-to-a-random-string-with-at-least-32-characters
JWT_EXPIRE_MINUTES=1440

# 管理员初始密码（可选）。不设置时系统会在首次启动生成一次性随机密码并打印到日志。
# ADMIN_INITIAL_PASSWORD=

# CORS 来源：开发环境默认只允许 http://localhost:3000
# 多来源用英文逗号分隔，例如：http://localhost:3000,https://app.example.com
# 生产环境严禁设置为 *，必须显式列出域名。
# CORS_ALLOW_ORIGINS=http://localhost:3000

# ===========================================================
# OSS 配置（可选）
# ===========================================================
# OSS_ENDPOINT=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=xlsx-bi
