# ===========================================================
# XLSX-to-BI 环境变量配置
# ===========================================================
# 复制此文件为 .env 并修改配置

# ===========================================================
# Agent 后端选择
# ===========================================================
# local    - 本地 LLM 提示词模式（推荐，需要 DashScope API Key）
# shenzhou - 神州问学平台（预留，待对接）
AGENT_BACKEND=local

# ===========================================================
# DashScope / 阿里云百炼 API（AGENT_BACKEND=local 时使用）
# ===========================================================
DASHSCOPE_API_KEY=sk-your-api-key-here
LLM_MODEL_QWEN_PRIMARY=qwen3-max
LLM_MODEL_QWEN_ALT=qwen3-235b

# ===========================================================
# 神州问学平台（AGENT_BACKEND=shenzhou 时使用，预留）
# ===========================================================
# SHENZHOU_API_BASE=https://api.shenzhou.com
# SHENZHOU_API_KEY=

# ===========================================================
# Agent 超时与重试配置
# ===========================================================
AGENT_MAX_RETRIES=2
AGENT_DEFAULT_TIMEOUT=60
AGENT_SQL_TIMEOUT=30
AGENT_SHEET_SUMMARY_TIMEOUT=20
AGENT_CHART_TIMEOUT=20
AGENT_REPORT_TIMEOUT=30

# ===========================================================
# 服务配置
# ===========================================================
DATABASE_URL=mysql+aiomysql://root:your-password@127.0.0.1:3306/xlsx_to_bi?charset=utf8mb4
SERVER_PORT=8000
JWT_SECRET_KEY=change-this-to-a-random-string-in-production
JWT_EXPIRE_MINUTES=1440

# ===========================================================
# OSS 配置（可选）
# ===========================================================
# OSS_ENDPOINT=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=xlsx-bi
