{
  "name": "parsight-frontend",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": "shaoxia20240902",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaoxia20240902/Parsight.git",
    "directory": "frontend"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx,.js,.jsx --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx,.js,.jsx --ignore-path .gitignore --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,js,json,css,scss}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.3",
    "marked": "^18.0.3",
    "pinia": "^2.1.7",
    "vue": "^3.3.8",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.7.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.20.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "vitest": "^1.2.0",
    "vue-tsc": "^3.2.9"
  }
}
